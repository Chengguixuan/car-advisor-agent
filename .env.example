# ==========================================================================
# 买车智能体 — 环境变量配置
# ==========================================================================
# 复制此文件为 .env 并填入你的实际配置。
#   cp .env.example .env
# ==========================================================================

# --- DeepSeek API 密钥（必填）---
# 在 https://platform.deepseek.com API Keys 页面获取
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# --- DeepSeek API 地址 ---
# 默认使用 DeepSeek 官方地址，无需修改
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- 模型名称 ---
# deepseek-chat:  通用对话模型（推荐）
# deepseek-reasoner: 推理增强模型
DEEPSEEK_MODEL=deepseek-chat

# --- 生成参数 ---
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=4096

# --- 对话设置 ---
# 保留的最近对话轮数（每轮 = 用户消息 + 助手回复），设为 0 不限制
MAX_HISTORY=20

# --- 调试模式 ---
# 设为 true 可在对话中输出调试信息
VERBOSE=false

# --- 向量模型镜像（国内用户推荐）---
# 设为 https://hf-mirror.com 可加速模型下载
HF_ENDPOINT=https://hf-mirror.com

# --- 服务化配置 ---
# API 服务端口
API_PORT=8000
# API 服务地址
API_HOST=0.0.0.0
