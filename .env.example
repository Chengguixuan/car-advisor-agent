# ==========================================================================
# 买车智能体 — 环境变量配置
# ==========================================================================
# 复制此文件为 .env 并填入你的实际配置。
#   cp .env.example .env
# ==========================================================================

# --- LLM 提供商选择 ---
# 可选值：openai | anthropic
LLM_PROVIDER=openai

# --- API 密钥（必填）---
LLM_API_KEY=sk-your-api-key-here

# --- 自定义 API 地址（可选）---
# 适用于中转代理、本地模型（如 Ollama、vLLM）等兼容接口。
# 例如：http://localhost:11434/v1
# LLM_API_BASE=

# --- 模型名称 ---
# OpenAI 默认 gpt-4o，Anthropic 默认 claude-sonnet-4-6-20250514
LLM_MODEL=gpt-4o

# --- 生成参数 ---
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# --- 对话设置 ---
# 保留的最近对话轮数（每轮 = 用户消息 + 助手回复），设为 0 不限制
MAX_HISTORY=20

# --- 调试模式 ---
# 设为 true 可在对话中输出调试信息
VERBOSE=false
